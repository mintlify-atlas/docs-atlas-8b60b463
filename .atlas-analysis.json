  "keyFeatures": [
    "Cross-platform desktop app for macOS, Windows, and Linux",
    "Support for 20+ databases including PostgreSQL, MySQL, SQLite, SQL Server, MongoDB, Redis, BigQuery, and more",
    "Autocomplete SQL query editor with syntax highlighting",
    "Visual table data editor with sorting and filtering",
    "Table structure editor and schema management",
    "Data import (CSV/JSON) and export (CSV, JSON, Excel, etc.)",
    "Entity Relationship Diagrams (ERD)",
    "Cloud workspaces for cross-machine and team collaboration",
    "SSH tunneling and secure connections",
    "Plugin system for extending functionality",
    "AI Shell plugin for natural-language database queries",
    "Privacy mode for screen-sharing sessions",
    "Saved queries and query history",
    "PIN lock mode and enterprise security configuration",
    "Dark and light themes"
  ],
